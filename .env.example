# ─────────────────────────────────────────────────────────────
#  Laura & Jordan — variables d'environnement
#  Copiez ce fichier en `.env.local` et remplissez les valeurs.
#  Sans ces variables, l'app tourne en MODE DÉMO (données de seed
#  en mémoire, emails loggés en console) — utile pour développer.
# ─────────────────────────────────────────────────────────────

# Supabase — https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Serveur uniquement — NE JAMAIS exposer côté client
SUPABASE_SERVICE_ROLE_KEY=

# Postgres Supabase (pooler recommandé) pour Drizzle
# Ex: postgres://postgres.xxxx:password@aws-0-eu-west-3.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Email — https://sendgrid.com → Settings → API Keys
#   Crée un « Single Sender » vérifié (Settings → Sender Authentication) :
#   permet d'envoyer à n'importe quelle adresse SANS domaine.
SENDGRID_API_KEY=
# Expéditeur = l'adresse Single Sender vérifiée ("Nom <email>" ou "email")
SENDGRID_FROM="Laura & Jordan <lauraetjordan@exemple.be>"
# Destinataires des notifications RSVP : définis dans le dashboard → Paramètres.

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Assets design (optionnels) — pour coller EXACTEMENT au projet Claude Design.
# Déposez les fichiers dans /public puis décommentez :
#   - le vrai motif toile de Jouy (roses/pivoines/colibris)
#   - la vraie vidéo d'ouverture d'enveloppe (WebM/MP4)
# NEXT_PUBLIC_MOTIF_SRC=/motif.png
# NEXT_PUBLIC_ENVELOPE_VIDEO=/envelope.webm

# Sel pour le hachage des IP (RSVP). Générez: `openssl rand -hex 16`
IP_HASH_SALT=change-me-in-production
